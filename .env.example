# Backblaze B2 (required)
B2_REGION=your-region-000
B2_APPLICATION_KEY_ID=your_application_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name

# Optional: public base URL for objects (only set if your bucket is public)
B2_PUBLIC_URL_BASE=

# Example of what filled-in values look like (fake — for visual reference only):
# B2_REGION=your-region
# B2_APPLICATION_KEY_ID=<24-hex-char keyID from the B2 app keys page>
# B2_APPLICATION_KEY=<31-char applicationKey shown once at key creation>
# B2_BUCKET_NAME=my-query-datasets
# B2_PUBLIC_URL_BASE=https://my-query-datasets.s3.your-region.backblazeb2.com
